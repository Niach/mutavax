# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
.eggs/

# Bioinformatics data (large files)
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bam.bai
*.cram
*.crai
*.sam
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.bed
*.fa
*.fa.fai
*.fasta
*.fasta.fai
*.dict
*.pdb
data/

# IDE
.idea/
.vscode/
.run/*
!.run/*.run.xml

# Local AI tooling
.claude/
.codex/

# Research intelligence cache and state
research/cache/*
!research/cache/.gitkeep
research/state/*
!research/state/.gitkeep
