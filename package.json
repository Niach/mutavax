{
  "name": "cancerstudio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "backend": "docker compose up",
    "backend:detached": "docker compose up -d && docker compose logs -f backend",
    "backend:down": "docker compose down",
    "dev:all": "concurrently -k -n next,backend \"npm run dev\" \"npm run backend\"",
    "lint": "eslint",
    "test:fast": "npm run lint && npx tsc --noEmit && npm run test:backend:fast",
    "test:backend:fast": "./.venv/bin/pytest -m \"not integration and not real_data\" backend/tests",
    "test:browser:integration": "playwright test tests/e2e/workflow-shell.spec.ts",
    "test:integration": "npm run test:browser:integration",
    "test:backend:real-data": "./.venv/bin/pytest -m \"integration and real_data\" backend/tests/test_real_data_ingestion.py",
    "test:browser:real-data": "playwright test tests/e2e/ingestion-real-data.spec.ts",
    "test:real-data": "npm run test:backend:real-data && npm run test:browser:real-data",
    "test:validation": "./.venv/bin/pytest -m validation backend/tests/validation",
    "research:run": "python3 scripts/run_research_intelligence.py",
    "research:dry-run": "python3 scripts/run_research_intelligence.py --dry-run",
    "sample-data:smoke": "python3 scripts/fetch_colo829_sample_data.py --mode smoke",
    "sample-data:full": "python3 scripts/fetch_colo829_sample_data.py --mode full",
    "sample-data:alignment": "python3 scripts/fetch_alignment_container_smoke_data.py",
    "docs:screenshots": "node scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.5.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
