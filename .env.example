# Local-only overrides belong in `.env`, which stays ignored.
# Keep repo-tracked config free of machine-specific absolute paths.

# Host storage path for MinIO data when using Docker Compose.
MINIO_DATA_DIR=./minio-data

# Local SQLite database path used only when DATABASE_URL is unset.
# Relative paths are resolved from the repository root.
LOCAL_SQLITE_PATH=backend/data/app.db

# Optional test override for the real-data smoke FASTQs.
# REAL_DATA_SAMPLE_DIR=./data/sample-data/seqc2-hcc1395-wes-ll/smoke
